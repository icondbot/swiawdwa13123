# iCondo Tennis Booker — environment variables
# Copy to .env for local development (never commit .env)

# Optional but recommended: protects all API routes. Set any random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=

# Required: bearer token extracted from the iCondo mobile app
# Effectively permanent (no real expiry)
ICONDO_TOKEN=eyJ...

# Optional: iCondo account credentials (used for re-authentication if needed)
ICONDO_USERNAME=your@email.com
ICONDO_PASSWORD=yourpassword

# Database (Render provides this automatically; set manually for local dev)
DATABASE_URL=postgresql://user:password@localhost:5432/icondo

# Dev server (Replit sets these automatically; not needed on Render)
PORT=8080
BASE_PATH=/
